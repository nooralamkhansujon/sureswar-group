8:["$","article",null,{"className":"message-card","style":{"maxWidth":760,"marginTop":28},"children":[["$","h3",null,{"children":"Ashraf Khan"}],["$","p",null,{"className":"role","children":"Chairman"}],["$","p",null,{"children":"Dear esteemed partners and associates, greetings from HiCare Services Ltd. It brings me great pleasure to introduce HiCare Services Ltd., a trustworthy and dependable name in the field of overseas employment for manpower and human resources. Our company operates a highly efficient network throughout Bangladesh and is fully equipped to recruit personnel who meet the requirements of our esteemed overseas employers."}],[["$","p","0",{"children":"Bangladesh is home to a surplus of talented, hardworking individuals who are eager to export their skills and contribute to economies around the world. Our workforce is known for dedication, loyalty, and honesty — qualities that employers value in every sector."}],["$","p","1",{"children":"HiCare Services Ltd. is equipped to provide skilled, semi-skilled, and unskilled manpower swiftly and professionally, and we invite potential clients to establish a long-term business relationship with us. We are committed to excellence, top-notch service, and a professional attitude as we work toward becoming a leading market player in the Middle East and other developed countries."}]],["$","p",null,{"className":"sign-off","children":["— ","Ashraf Khan",", ","Chairman"]}]]}]
9:["$","section",null,{"id":"message-md","className":"hicare-section message-section","children":[["$","span",null,{"className":"section-label","children":"Managing Director"}],["$","h2",null,{"className":"section-title","children":["Message from the ",["$","span",null,{"children":"Managing Director"}]]}],["$","p",null,{"className":"section-desc","children":"S. N. Manzur Murshed (Mahbub) on capability, markets, and how we work with employers."}],["$","article",null,{"className":"message-card","style":{"maxWidth":760,"marginTop":28},"children":[["$","h3",null,{"children":"S. N. Manzur Murshed (Mahbub)"}],["$","p",null,{"className":"role","children":"Managing Director"}],["$","p",null,{"children":"Dear valued partners and associates, greetings from HiCare Services Ltd. I am pleased to introduce our agency as a modern, efficient, and leading overseas recruiting agency in Bangladesh. Our unwavering commitment to high-quality, professional services has earned us reliability, trustworthiness, and global appreciation."}],[["$","p","0",{"children":"Bangladesh, with its dense population, presents a unique opportunity to help develop the economic structures of countries suffering from a shortage of skilled manpower. We believe that “people are resources” and have devoted ourselves to discovering the best candidates and instilling a sense of responsibility in them. Our technical training and testing center ensures that we maintain an unparalleled database of potential employees with exceptional technical skills who are highly sought after in the market."}],["$","p","1",{"children":"In today’s highly competitive job market, finding the right candidate for a vacancy can be challenging. Without the appropriate expertise, scouting for the ideal candidate can waste significant time and money. If you face this dilemma, consider delegating the task to us. We have the knowledge and experience to mobilize the right personnel for your company at a reasonable cost and in accordance with your requirements."}],["$","p","2",{"children":"I hope this profile gives you a better understanding of our company and the services we offer."}]],["$","p",null,{"className":"sign-off","children":["— ","S. N. Manzur Murshed (Mahbub)",", ","Managing Director"]}]]}]]}]
a:["$","section",null,{"id":"overview","className":"hicare-section overview","children":[["$","div",null,{"className":"overview-left","children":[["$","span",null,{"className":"section-label","children":"Overview"}],["$","h2",null,{"className":"section-title","children":["HiCare ",["$","span",null,{"children":"Services Ltd."}]]}],[["$","p","0",{"className":"section-desc","style":{"marginTop":16},"children":"HiCare Services Ltd. is a reputable agency in Bangladesh that has been approved by the government as a manpower recruiting agency with license No. RL-2234. The agency is registered under the Ministry of Expatriates Welfare & Overseas Employment and has become a foremost conglomerate in Bangladesh. HiCare Services Ltd. is also a member of the Bangladesh Association of International Recruiting Agencies (BAIRA)."}],["$","p","1",{"className":"section-desc","style":{"marginTop":16},"children":"The company recognizes the need for a professionally managed recruitment agency to connect job opportunities with job seekers, which is why HiCare Services Ltd. was established. Our goal is to provide competitive, efficient, and reliable human resource solutions to become a leading provider in this industry — a position reflected in our standing today."}]],["$","div",null,{"className":"training-block","children":[["$","h3",null,{"children":"Training & social responsibility"}],[["$","p","0",{"className":"section-desc","style":{"marginTop":12},"children":"As a socially responsible company, HiCare Services Ltd. believes in strengthening the diversity of our communities and creating opportunities for all people to participate in the workforce. The company focuses on developing sustainable solutions for the long term and on bridging the gap between employers and individuals. By identifying skills gaps and helping people engage with the workforce, we connect job seekers with opportunities that benefit both parties."}],["$","p","1",{"className":"section-desc","style":{"marginTop":12},"children":"To ensure that quality human resources are sourced for our valued partners, HiCare Services Ltd. has developed its own training center. Candidates seeking overseas employment may face challenges adjusting to new work environments, language, culture, and norms — so HiCare Training Institute offers training and induction courses for both overseas employment seekers and employers. Our systems, programs, and policies are designed to make employment a viable option for those who need it. We focus on people’s abilities, not their disabilities, and do not discriminate against anyone."}]]]}]]}],["$","aside",null,{"className":"overview-right","aria-label":"Registration details","children":[["$","h3",null,{"children":"At a glance"}],["$","div",null,{"className":"info-row","children":[["$","span",null,{"className":"key","children":"License"}],["$","span",null,{"className":"val","children":"RL-2234"}]]}],["$","div",null,{"className":"info-row","children":[["$","span",null,{"className":"key","children":"Incorporation"}],["$","span",null,{"className":"val","children":["C-181931/2022",["$","br",null,{}],"22 June 2022",", Dhaka"]}]]}],["$","div",null,{"className":"info-row","children":[["$","span",null,{"className":"key","children":"Membership"}],["$","span",null,{"className":"val","children":"Bangladesh Association of International Recruiting Agencies (BAIRA)"}]]}],["$","div",null,{"className":"info-row","children":[["$","span",null,{"className":"key","children":"Ministry"}],["$","span",null,{"className":"val","children":"Ministry of Expatriates' Welfare & Overseas Employment"}]]}],["$","div",null,{"className":"info-row","children":[["$","span",null,{"className":"key","children":"Website"}],["$","span",null,{"className":"val","children":["$","a",null,{"href":"https://www.hicare.com.bd","style":{"color":"var(--blue)","fontWeight":600},"children":"www.hicare.com.bd"}]}]]}]]}]]}]
b:["$","section",null,{"id":"bangladesh","className":"hicare-section","style":{"background":"white"},"children":[["$","span",null,{"className":"section-label","children":"Context"}],["$","h2",null,{"className":"section-title","children":["A brief overview of ",["$","span",null,{"children":"Bangladesh"}]]}],["$","p",null,{"className":"section-desc","children":"Bangladesh offers scale, skills, and infrastructure momentum that support sustainable overseas employment partnerships."}],["$","ul",null,{"className":"bd-list","children":[["$","li","Home to the world’s largest delta and the seventh-largest human-made reservoir.",{"children":"Home to the world’s largest delta and the seventh-largest human-made reservoir."}],["$","li","Second-largest pool of human resources in the world.",{"children":"Second-largest pool of human resources in the world."}],["$","li","Second-largest contributor of United Nations peacekeeping troops.",{"children":"Second-largest contributor of United Nations peacekeeping troops."}],["$","li","Bangladeshi engineers work for global MNCs; doctors practice medicine worldwide.",{"children":"Bangladeshi engineers work for global MNCs; doctors practice medicine worldwide."}],["$","li","One of the fastest-growing economies, with average GDP growth around 6–7% over the last decade.",{"children":"One of the fastest-growing economies, with average GDP growth around 6–7% over the last decade."}],["$","li","Strong progress in ready-made garments, agriculture, fisheries, IT, and human resources export.",{"children":"Strong progress in ready-made garments, agriculture, fisheries, IT, and human resources export."}],["$","li","Poverty rate reduced from 41.5% (2005) to 24.3% (2016) per World Bank data.",{"children":"Poverty rate reduced from 41.5% (2005) to 24.3% (2016) per World Bank data."}],["$","li","Major infrastructure: Padma Bridge, MRT Metrorail, Dhaka Airport 3rd Terminal, Cox’s Bazar Airport upgrade.",{"children":"Major infrastructure: Padma Bridge, MRT Metrorail, Dhaka Airport 3rd Terminal, Cox’s Bazar Airport upgrade."}],["$","li","A growing middle class drives demand for consumer goods, housing, education, and healthcare.",{"children":"A growing middle class drives demand for consumer goods, housing, education, and healthcare."}],["$","li","Special Economic Zones (SEZs) for textiles, electronics, and pharmaceuticals.",{"children":"Special Economic Zones (SEZs) for textiles, electronics, and pharmaceuticals."}],["$","li","Government reforms to simplify regulations and attract foreign investment.",{"children":"Government reforms to simplify regulations and attract foreign investment."}],["$","li","Strategic location between South and Southeast Asia for trade with neighboring countries.",{"children":"Strategic location between South and Southeast Asia for trade with neighboring countries."}]]}]]}]
